<cc:RuMCDemolitionsScannerWindow xmlns="https://spacestation14.io"
                                 xmlns:cc="clr-namespace:Content.Client._RuMC14.Ordnance"
                                 Title="Demolitions Scanner"
                                 MinSize="520 360"
                                 SetSize="520 360">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <Label Name="StatusLabel"
               Access="Public"
               Text="Scan a custom casing to display a full readout."
               FontColorOverride="#8fa1b8" />

        <PanelContainer>
            <BoxContainer Orientation="Horizontal" Margin="8" SeparationOverride="12">
                <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                    <Label Text="Casing Overview"
                           FontColorOverride="#d9e8ff" />
                    <Label Name="CasingLabel" Access="Public" Text="-" />
                    <Label Name="StageLabel" Access="Public" Text="-" />
                    <Label Name="DetonatorLabel" Access="Public" Text="-" />
                    <Label Name="VolumeLabel" Access="Public" Text="-" />
                </BoxContainer>

                <Control MinSize="1 0" />

                <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                    <Label Text="Blast Estimate"
                           FontColorOverride="#ffd37a" />
                    <RichTextLabel Name="BlastLabel" Access="Public" />
                    <Label Text="Incendiary Estimate"
                           Margin="0 6 0 0"
                           FontColorOverride="#ff9d6b" />
                    <RichTextLabel Name="FireLabel" Access="Public" />
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>

        <PanelContainer VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="6">
                <Label Text="Tactical Summary"
                       FontColorOverride="#9effb6" />
                <RichTextLabel Name="SummaryLabel"
                               Access="Public"
                               VerticalExpand="True" />
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</cc:RuMCDemolitionsScannerWindow>
