<cc:RuMCExplosionSimulatorWindow xmlns="https://spacestation14.io"
                                 xmlns:cc="clr-namespace:Content.Client._RuMC14.Ordnance"
                                 Title="Explosion Simulation Computer"
                                 MinSize="740 560"
                                 SetSize="740 560">
    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="8">
        <PanelContainer StyleClasses="Inset">
            <BoxContainer Orientation="Horizontal" Margin="10" SeparationOverride="12">
                <BoxContainer Orientation="Vertical" HorizontalExpand="True" SeparationOverride="4">
                    <RichTextLabel Name="HeaderLabel"
                                   Access="Public" />
                    <Label Text="Two-minute predictive analysis for custom explosive payloads."
                           FontColorOverride="#7c8ea8" />
                </BoxContainer>

                <PanelContainer>
                    <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="4">
                        <Label Text="Analysis Cycle"
                               FontColorOverride="#b8d5ff" />
                        <ProgressBar Name="ProcessingBar"
                                     Access="Public"
                                     HorizontalExpand="True"
                                     MaxValue="1"
                                     MinValue="0"
                                     SetSize="220 24">
                            <Label Name="ProcessingLabel"
                                   Access="Public"
                                   HorizontalAlignment="Center"
                                   Margin="4 0"
                                   Text="Standby" />
                        </ProgressBar>
                    </BoxContainer>
                </PanelContainer>
            </BoxContainer>
        </PanelContainer>

        <BoxContainer Orientation="Horizontal" SeparationOverride="8" VerticalExpand="True">
            <PanelContainer HorizontalExpand="True" VerticalExpand="True">
                <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="8">
                    <Label Text="Target Profile"
                           FontColorOverride="#d9e8ff" />
                    <Label Text="Select the formation to seed into the replay chamber."
                           FontColorOverride="#7c8ea8" />

                    <Button Name="MarinesButton"
                            Access="Public"
                            Text="USCM Marines"
                            MinSize="0 36" />
                    <Button Name="SpecialForcesButton"
                            Access="Public"
                            Text="Special Forces"
                            MinSize="0 36" />
                    <Button Name="XenomorphsButton"
                            Access="Public"
                            Text="Xenomorph Hive"
                            MinSize="0 36" />

                    <PanelContainer StyleClasses="Inset" VerticalExpand="True">
                        <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="4">
                            <Label Text="Threat Notes"
                                   FontColorOverride="#9effb6" />
                            <RichTextLabel Name="TargetNotesLabel"
                                           Access="Public"
                                           VerticalExpand="True" />
                        </BoxContainer>
                    </PanelContainer>

                    <PanelContainer StyleClasses="Inset">
                        <BoxContainer Orientation="Vertical" Margin="8" SeparationOverride="4">
                            <Label Text="Sample Status"
                                   FontColorOverride="#ffd37a" />
                            <Label Name="BeakerLabel"
                                   Access="Public"
                                   Text="No beaker inserted." />
                            <RichTextLabel Name="ReadinessLabel"
                                           Access="Public" />
                        </BoxContainer>
                    </PanelContainer>
                </BoxContainer>
            </PanelContainer>

            <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True" SeparationOverride="8">
                <PanelContainer HorizontalExpand="True">
                    <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="4">
                        <Label Text="Blast Projection"
                               FontColorOverride="#ffd37a" />
                        <RichTextLabel Name="BlastLabel"
                                       Access="Public" />
                    </BoxContainer>
                </PanelContainer>

                <PanelContainer HorizontalExpand="True">
                    <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="4">
                        <Label Text="Incendiary Projection"
                               FontColorOverride="#ff9d6b" />
                        <RichTextLabel Name="FireLabel"
                                       Access="Public" />
                    </BoxContainer>
                </PanelContainer>

                <PanelContainer HorizontalExpand="True" VerticalExpand="True">
                    <BoxContainer Orientation="Vertical" Margin="10" SeparationOverride="6">
                        <Label Text="Simulation Summary"
                               FontColorOverride="#9effb6" />
                        <RichTextLabel Name="StatusLabel"
                                       Access="Public"
                                       VerticalExpand="True" />
                    </BoxContainer>
                </PanelContainer>

                <BoxContainer Orientation="Horizontal" SeparationOverride="8">
                    <Button Name="SimulateButton"
                            Access="Public"
                            Text="Run 120s Analysis"
                            HorizontalExpand="True"
                            MinSize="0 36" />
                    <Button Name="ReplayButton"
                            Access="Public"
                            Text="Replay Chamber"
                            HorizontalExpand="True"
                            MinSize="0 36"
                            Disabled="True" />
                </BoxContainer>
            </BoxContainer>
        </BoxContainer>

        <BoxContainer Orientation="Horizontal" Margin="4 0 4 0">
            <Label Text="Explosion Analysis Suite"
                   StyleClasses="WindowFooterText" />
            <Label Text="OT Research Annex"
                   StyleClasses="WindowFooterText"
                   HorizontalAlignment="Right"
                   HorizontalExpand="True" />
        </BoxContainer>
    </BoxContainer>
</cc:RuMCExplosionSimulatorWindow>
