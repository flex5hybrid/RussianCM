<controls:CorporateConsoleThirdPartyWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.AU14.ColonyEconomy"
    Title="Call Third Party Support (Corporate)" MinSize="400 300">
    <BoxContainer Orientation="Vertical" HorizontalExpand="True" Margin="8">
        <Label Name="BudgetLabel" Access="Public" Text="Corporate Budget: $0"
               StyleClasses="LabelHeading" Margin="4 4" />
        <Label Text="Available Third Parties:" StyleClasses="LabelHeading" Margin="4 8" />
        <BoxContainer Orientation="Horizontal" Margin="4 4">
            <OptionButton Name="ThirdPartySelect" Access="Public" HorizontalExpand="True" Margin="2 0" />
        </BoxContainer>
        <Label Name="CostLabel" Access="Public" Text="Cost: $0" Margin="4 4" />
        <Button Name="CallBtn" Access="Public" Text="Request Support"
                HorizontalExpand="True" Margin="4 8" />
        <Label Name="StatusLabel" Access="Public" Text="" Margin="4 4" />
    </BoxContainer>
</controls:CorporateConsoleThirdPartyWindow>

