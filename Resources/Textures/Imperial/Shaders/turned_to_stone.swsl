void fragment() {
    highp vec3 BT709 = vec3(0.2126, 0.7152, 0.0722); // https://ru.wikipedia.org/wiki/Rec._709
    highp vec4 texture = zTexture(UV);

    highp float greyed = dot(BT709, texture.rgb);

    COLOR = vec4(vec3(greyed), texture.a);
}
